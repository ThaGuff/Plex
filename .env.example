# ───────────────────────────────────────────────────────────
# LeadLoop SaaS — environment variables
# ───────────────────────────────────────────────────────────

# Database
# Local dev (default): SQLite
DATABASE_URL="file:./dev.db"
# Production (Railway / Postgres):
# DATABASE_URL="postgresql://user:pass@host:5432/leadloop?schema=public"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-char-secret"

# Apify Leads Finder API
# Sign up: https://apify.com/code_crafter/leads-finder?fpr=p2hrc6
APIFY_TOKEN=""
APIFY_ACTOR_ID="code_crafter~leads-finder"

# Default admin (created by seed)
ADMIN_EMAIL="admin@leadloop.dev"
ADMIN_PASSWORD="admin1234"

# Demo user (created by seed)
DEMO_EMAIL="demo@leadloop.dev"
DEMO_PASSWORD="demo1234"

# App
NEXT_PUBLIC_APP_NAME="LeadLoop"
APP_URL="http://localhost:3000"
